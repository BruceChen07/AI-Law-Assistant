{
    "data_dir": "../data",
    "db_path": "../data/app.db",
    "files_dir": "../data/files",
    "static_dir": "../web/dist",
    "default_language": "zh",
    "reranker_enabled": true,
    "reranker_model_path": "",
    "reranker_profiles": {
        "en": "../models/reranker/en"
    },
    "rerank_batch_size": 8,
    "rerank_max_len": 512,
    "rerank_fallback": true,
    "rerank_score_threshold": 0.0,
    "embedding_profiles": {
        "zh": {
            "embedding_model": "../models/embedding/zh/model.onnx",
            "embedding_tokenizer_dir": "../models/embedding/zh",
            "embedding_model_id": "BAAI/bge-small-zh-v1.5",
            "embedding_source": "modelscope",
            "embedding_max_seq_len": 512,
            "embedding_pooling": "cls",
            "embedding_query_instruction": "为这个句子生成表示以用于检索相关文章：",
            "embedding_threads": 2
        },
        "en": {
            "embedding_model": "..\\models\\embedding\\en\\model.onnx",
            "embedding_tokenizer_dir": "..\\models\\embedding\\en",
            "embedding_model_id": "BAAI/bge-small-en-v1.5",
            "embedding_source": "modelscope",
            "embedding_max_seq_len": 512,
            "embedding_pooling": "cls",
            "embedding_threads": 2,
            "embedding_query_instruction": "Represent this sentence for retrieving relevant passages:"
        }
    },
    "log_level": "INFO",
    "log_base_dir": "../logs",
    "log_dir": "../logs",
    "log_max_bytes": 10485760,
    "log_backup_count": 7,
    "log_when": "midnight",
    "log_interval": 1,
    "ocr_enabled": true,
    "ocr_languages": "chi_sim+eng",
    "ocr_min_text_length": 200,
    "ocr_dpi": 220,
    "ocr_engine": "auto",
    "ocr_engine_order": [
        "tesseract",
        "mineru"
    ],
    "ocr_engine_by_type": {
        "pdf": "tesseract"
    },
    "ocr_engines": {
        "mineru": {
            "module": "app.core.mineru_ocr",
            "function": "ocr_pdf"
        }
    },
    "llm_config": {
        "provider": "qwen",
        "api_base": "https://dashscope.aliyuncs.com/compatible-mode/v1",
        "api_key": "",
        "model": "kimi-k2.5",
        "temperature": 0.0,
        "max_tokens": 2048,
        "timeout": 120,
        "headers": {}
    },
    "llm_trace_enabled": true,
    "llm_trace_dir": "../data/memory/llm_interactions",
    "llm_trace_max_chars": 12000,
    "rag_trace_enabled": true,
    "rag_trace_dir": "../data/memory/debug/rag_retrieval",
    "rag_trace_max_chars": 3000,
    "rag_trace_max_rows": 20,
    "retrieval_regulation_language": "zh",
    "jieba_user_dict_path": "../data/dict/law_dict.txt",
    "jieba_hmm_enabled": false,
    "jieba_force_words": [
        "税收征收管理法实施细则",
        "税收征收管理法",
        "增值税专用缴款书",
        "增值税专用发票",
        "虚开增值税专用发票罪",
        "代扣代缴义务人",
        "小规模纳税人",
        "一般纳税人",
        "企业所得税法",
        "个人所得税法",
        "土地增值税暂行条例",
        "营业税暂行条例",
        "资源税暂行条例",
        "税收强制执行措施",
        "出口退税",
        "税务稽查",
        "税务行政复议",
        "税务行政处罚",
        "税前扣除",
        "纳税申报",
        "税务申报",
        "会计基础工作规范",
        "会计档案管理办法",
        "中华人民共和国审计法",
        "注册会计师法",
        "银行承兑汇票",
        "商业承兑汇票",
        "国有资本经营预算制度"
    ],
    "translation_config": {
        "enabled": true,
        "backend": "hy_mt_local",
        "mode": "dual",
        "cross_lang_source_query_enabled": false,
        "model_id": "tencent/HY-MT1.5-1.8B",
        "model_dir": "",
        "device": "cuda",
        "source_langs": [
            "en"
        ],
        "target_lang": "zh"
    },
    "memory_use_long_hits": false,
    "memory_enable_long_memory": false,
    "memory_enable_short_memory": true,
    "max_upload_mb": 50,
    "cors_allow_origins": [
        "http://localhost:5173",
        "http://localhost:5174"
    ],
    "ui_config": {
        "show_citation_source": false,
        "default_theme": "dark"
    }
}